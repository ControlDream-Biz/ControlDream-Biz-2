# 应用配置
NEXT_PUBLIC_APP_NAME=创梦计算机系统有限公司
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_APP_ENV=production

# 授权域名（多个域名用逗号分隔）
NEXT_PUBLIC_AUTHORIZED_DOMAIN=chuangmeng.com,www.chuangmeng.com

# 安全配置
NEXT_PUBLIC_SECURITY_ENABLED=true

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/chuangmeng

# API 配置
NEXT_PUBLIC_API_URL=https://api.chuangmeng.com

# 监控和分析
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# 开发/生产环境标识
COZE_PROJECT_ENV=PROD
