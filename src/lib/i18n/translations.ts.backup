    'chat.title': 'Online Support',
    'chat.placeholder': 'Please enter your question...',
    'chat.send': 'Send',
    'chat.welcome': 'Hello! Welcome to Chuangmeng Computer System Co., Ltd. I am your dedicated customer service representative. How can I help you?',
    'chat.connecting': 'Connecting to customer service...',
    'chat.offline': 'Customer service is currently offline. Please leave a message.',
    'chat.agent_prefix': 'Customer Service Agent',
    'chat.agent_id': 'Agent ID',
    'chat.online': 'Online',
    'chat.minimize': 'Minimize',
    'chat.expand': 'Expand',
    'chat.close': 'Close',
    'chat.typing': 'Agent is typing...',
    'chat.product_info': 'Our products include three major sectors: Gaming Innovation, Software Empowerment, and Hardware Intelligence.\n\n🎮 Gaming Innovation: Independent R&D of high-quality game products, providing game engine technical support\n💻 Software Empowerment: Enterprise-level software development, cloud computing solutions, AI application development\n🔧 Hardware Intelligence: High-performance computer equipment, gaming peripherals, embedded systems\n\nWhich aspect would you like to know more about?',
    'chat.game_info': 'Our gaming innovation sector offers:\n\n🎮 Original game IP development\n🎮 Game engine technical support and optimization\n🎮 Game customization development, art outsourcing, technical consulting\n🎮 Game operations and distribution services\n\nIf you have specific project requirements, welcome to contact us!',
    'chat.software_info': 'Our software empowerment sector includes:\n\n💻 Enterprise-level software development and system integration\n💻 Cloud computing solutions and SaaS products\n💻 AI application development and data services\n💻 Digital transformation technical support\n\nWe can provide customized solutions for various industries.',
    'chat.hardware_info': 'Our hardware intelligence sector covers:\n\n🔧 R&D and production of high-performance computer equipment\n🔧 Design and manufacturing of gaming peripherals and related products\n🔧 Embedded system development and IoT solutions\n🔧 Hardware customization services\n\nWe have complete hardware R&D and production capabilities.',
    'chat.cooperation': 'Thank you very much for your interest in our products! We highly value our partnerships.\n\n📞 Please contact us through:\n• Customer service hotline: 400-XXX-XXXX\n• Email: contact@chuangmeng.com\n• Or fill out the contact form at the bottom of the page\n\nWe will communicate with you about cooperation matters as soon as possible!',
    'chat.price': 'Our product solutions are customized according to specific needs, so prices may vary.\n\n💰 We offer flexible pricing schemes:\n• Project-based pricing\n• Usage-based pricing\n• Customized solutions\n\nWe suggest you contact us first for requirement assessment, and we will provide a detailed quotation.',
    'chat.contact': 'You can contact us through the following ways:\n\n📞 Customer service hotline: 400-XXX-XXXX (7×12 hours service)\n📧 Email: contact@chuangmeng.com\n🌐 Official website: https://chuangmeng.com\n📍 Address: China · Shenzhen\n\nOr fill out the contact form at the bottom of the page, we will reply to you as soon as possible!',
    'chat.about': 'Chuangmeng Computer System Co., Ltd. is an innovative enterprise focusing on digital entertainment and intelligent technology.\n\n🏢 Our Mission:\nDedicated to independent product R&D and operations, creating an independent product ecosystem in three areas: gaming, software, and hardware.\n\n🏆 Our Advantages:\n• Experienced technical R&D team\n• Multiple independent intellectual property rights\n• Perfect customer service system\n• Long-term cooperation with many well-known enterprises\n\nWelcome to learn more!',
    'chat.thanks': 'You\'re welcome! 🙏\n\nIf you have any other questions, feel free to contact us at any time. Have a nice day!\n\nWe will always be here to help you.',
    'chat.greeting': 'Hello! Nice to meet you! 👋\n\nI am your dedicated customer service agent, Agent ID: {agentId}\n\nHow can I help you? You can ask about:\n• Our products and services\n• Cooperation matters\n• Pricing information\n• Contact information',
    'chat.default': 'Thank you for your inquiry! 🤝\n\nOur professional customer service staff will answer your questions as soon as possible.\n\nYou can also contact us directly through:\n📞 Customer service hotline: 400-XXX-XXXX\n📧 Email: contact@chuangmeng.com\n\nIs there anything else I can help you with?',

    // ========== Floating Buttons ==========
    'float.back_to_top': 'Scroll Up (Double-click to return to home)',
    'float.back_to_top_hint': 'Single click to scroll up, double-click to return to home',
    'float.contact_service': 'Contact Support',
    'float.service_hint': 'Need help? Click to contact support',
    'float.service_hint_emoji': '💬',
  },

